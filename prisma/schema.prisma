generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  BLOCKED
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AttachmentType {
  IMAGE
  PDF
  LINK
}

enum PartnerType {
  ACTIVE
  PASSIVE
}

enum InventoryCategory {
  AUDIO
  LIGHTING
  BRANDING
  TECHNOLOGY
  PRODUCTION
}

enum InventoryStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  RETIRED
}

enum FinancialType {
  INCOME
  EXPENSE
}

enum InvoiceStatus {
  INVOICED
  RECEIVABLE
  PAID
  VOID
}

enum DocumentStatus {
  PROJECTED
  CONFIRMED
  INVOICED
  PARTIALLY_COLLECTED
  COLLECTED
  VOID
  APPROVED
  COMMITTED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  SETTLED
}

enum TaxType {
  NONE
  IVA
  RENTA
}

enum EventLineType {
  INCOME
  EXPENSE
  PERSONNEL
  SPONSOR
}

enum EventStatus {
  PLANNING
  ACTIVE
  CLOSED
  CANCELLED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String          @default("ADMIN")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  accounts      Account[]
  sessions      Session[]
  assignedTasks Task[]          @relation("TaskAssignee")
  comments      Comment[]
  activityLogs  ActivityLog[]
  attachments   Attachment[]
  inventory     Inventory[]
  eventLineActions EventLineItem[] @relation("EventLineActionedBy")

  @@map("users")
}

model Phase {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  order       Int      @default(0)
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("phases")
}

model Task {
  id            String        @id @default(cuid())
  title         String
  description   String        @db.Text
  status        TaskStatus    @default(PENDING)
  priority      Priority      @default(MEDIUM)
  progress      Int           @default(0)
  tags          String[]      @default([])
  createdAt     DateTime      @default(now())
  completedAt   DateTime?
  archived      Boolean       @default(false)
  archivedAt    DateTime?
  updatedAt     DateTime      @updatedAt
  phaseId       String
  assigneeId    String?
  responsiblePartnerId String?
  phase         Phase         @relation(fields: [phaseId], references: [id])
  assignee      User?         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  responsiblePartner Partner? @relation(fields: [responsiblePartnerId], references: [id], onDelete: SetNull)
  comments      Comment[]
  attachments   Attachment[]
  activityLogs  ActivityLog[]

  @@index([status, priority])
  @@index([phaseId])
  @@index([responsiblePartnerId])
  @@map("tasks")
}

model Comment {
  id        String   @id @default(cuid())
  body      String   @db.Text
  createdAt DateTime @default(now())
  taskId    String
  userId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@map("comments")
}

model Attachment {
  id        String         @id @default(cuid())
  name      String
  url       String         @db.Text
  type      AttachmentType
  createdAt DateTime       @default(now())
  taskId    String
  userId    String?
  task      Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User?          @relation(fields: [userId], references: [id])

  @@map("attachments")
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  taskId    String?
  userId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@map("activity_logs")
}

model Event {
  id            String         @id @default(cuid())
  eventId       String         @unique
  slug          String         @unique
  name          String
  date          DateTime
  budget        Decimal        @db.Decimal(14, 2)
  status        EventStatus    @default(PLANNING)
  sponsors      String[]       @default([])
  attendees     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  eventFinances EventFinance[]
  lineItems     EventLineItem[]
  financialRecords FinancialRecord[]

  @@map("events")
}

model EventLineItem {
  id          String        @id @default(cuid())
  eventId     String
  event       Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type        EventLineType
  concept     String
  quantity    Int           @default(1)
  unitCost    Decimal       @db.Decimal(14, 2)
  projected   Decimal       @db.Decimal(14, 2)
  actual      Decimal       @db.Decimal(14, 2)
  paid        Boolean       @default(false)
  financialStatus PaymentStatus @default(PENDING)
  actionedById String?
  actionedBy   User?        @relation("EventLineActionedBy", fields: [actionedById], references: [id], onDelete: SetNull)
  actionedAt   DateTime?
  responsible String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([eventId, type])
  @@index([financialStatus])
  @@index([actionedById])
  @@map("event_line_items")
}

model EventFinance {
  id        String   @id @default(cuid())
  income    Decimal  @db.Decimal(14, 2)
  expenses  Decimal  @db.Decimal(14, 2)
  utility   Decimal  @db.Decimal(14, 2)
  roi       Decimal  @db.Decimal(8, 2)
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("event_finances")
}

model Partner {
  id            String      @id @default(cuid())
  name          String
  type          PartnerType @default(ACTIVE)
  contribution  Decimal     @db.Decimal(14, 2)
  withdrawals   Decimal     @db.Decimal(14, 2)
  loans         Decimal     @db.Decimal(14, 2)
  participation Decimal     @db.Decimal(5, 2)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  tasks         Task[]

  @@map("partners")
}

model Inventory {
  id          String            @id @default(cuid())
  code        String            @unique
  name        String
  category    InventoryCategory
  value       Decimal           @db.Decimal(14, 2)
  status      InventoryStatus   @default(AVAILABLE)
  location    String
  responsible String
  userId      String?
  user        User?             @relation(fields: [userId], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("inventory")
}

model FinancialRecord {
  id          String        @id @default(cuid())
  type        FinancialType
  category    String
  description String
  amount      Decimal       @db.Decimal(14, 2)
  month       DateTime
  projected   Boolean       @default(false)
  invoiceStatus InvoiceStatus @default(PAID)
  documentStatus DocumentStatus @default(PROJECTED)
  paymentStatus PaymentStatus @default(PENDING)
  paidAmount  Decimal       @default(0) @db.Decimal(14, 2)
  pendingBalance Decimal    @default(0) @db.Decimal(14, 2)
  dueDate     DateTime?
  responsible String?
  eventId     String?
  event       Event?        @relation(fields: [eventId], references: [id], onDelete: SetNull)
  deletedAt   DateTime?
  taxType     TaxType       @default(NONE)
  taxPaid     Boolean       @default(false)
  bankAccountId String?
  bankAccount BankAccount?  @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  payments    MovementPayment[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([type, month])
  @@index([bankAccountId])
  @@index([eventId])
  @@map("financial_records")
}

model MovementPayment {
  id          String          @id @default(cuid())
  movementId  String
  movement    FinancialRecord @relation(fields: [movementId], references: [id], onDelete: Cascade)
  bankAccountId String
  bankAccount BankAccount    @relation(fields: [bankAccountId], references: [id])
  amount      Decimal         @db.Decimal(14, 2)
  paidAt      DateTime        @default(now())
  note        String?
  createdAt   DateTime        @default(now())

  @@index([movementId])
  @@index([bankAccountId])
  @@map("movement_payments")
}

model FinancialCategory {
  id        String        @id @default(cuid())
  name      String
  type      FinancialType
  createdAt DateTime      @default(now())

  @@unique([name, type])
  @@map("financial_categories")
}

model BankAccount {
  id          String            @id @default(cuid())
  name        String
  bank        String
  accountNo   String?
  currency    String            @default("COP")
  balance     Decimal           @db.Decimal(14, 2)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  records     FinancialRecord[]
  payments    MovementPayment[]

  @@map("bank_accounts")
}
